# Copy this to .env and update with your deployed backend URL for mobile/production

# API base URL for axios requests (include /api at the end)
# Local: http://localhost:5000/api
# Production: https://your-backend.onrender.com/api
REACT_APP_API_BASE_URL=https://realestate-backend.onrender.com/api

# Backend URL for image paths (no /api)
# Local: http://localhost:5000
# Production: https://your-backend.onrender.com
REACT_APP_BACKEND_URL=https://realestate-backend.onrender.com
