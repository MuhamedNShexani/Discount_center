# Copy to .env (local) or set these in your CI/hosting BEFORE `npm run build`.
# Vite bakes VITE_* into the bundle at build time — not at runtime on the server.
#
# App update banner: bump `frontend/package.json` `version` before each deploy.
# `prebuild` runs `scripts/write-version.js` → `public/version.json` (copied to `build/`).
# Configure your CDN/server so `/version.json` is not cached for a long time (or short max-age).

# --- Local dev (npm start in frontend/) — talks to backend on :5000 + local Mongo from root .env
VITE_API_BASE_URL=http://localhost:5000/api
VITE_BACKEND_URL=http://localhost:5000

# --- Production (Railway) — set in .env.production or CI before `npm run build` for Hostgator/deploy
# VITE_API_BASE_URL=https://discountcenter-production.up.railway.app/api
# VITE_BACKEND_URL=https://discountcenter-production.up.railway.app

# Vercel only: same-origin `/api` + `vercel.json` rewrites to Railway (set false or omit if using VITE_API_BASE_URL above)
# VITE_USE_PROXY=true

# Optional: default axios timeout in ms (default 10000). Long uploads use per-request overrides.
# VITE_API_TIMEOUT_MS=10000

# Set to true in a staging build to show the in-app network debug strip + extra console logging.
# VITE_DEBUG_NETWORK=true

# Optional: comma-separated hostnames that stay in-app when linked (e.g. preview.dashkan.net)
# VITE_INTERNAL_LINK_HOSTS=preview.example.com

# Google Sign-In on /login — must match server GOOGLE_CLIENT_ID (OAuth 2.0 Web client)
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# Optional: full-page OAuth for WebView testing in desktop browser
# VITE_GOOGLE_OAUTH_REDIRECT=true
