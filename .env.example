# Backend environment variables
# Copy to .env and fill in values

# MongoDB connection
MONGO_URI=mongodb://localhost:27017/storeplace

# Server port
PORT=5000

# JWT secret for auth
JWT_SECRET=your-secret-key

# Google Sign-In (same OAuth 2.0 Web Client ID as REACT_APP_GOOGLE_CLIENT_ID in frontend)
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs (Web application)
# Authorized JavaScript origins: http://localhost:3000, https://your-production-domain
GOOGLE_CLIENT_ID=230477938613-sgt7e78cve9vne6k6ku3r6vvphohgfuh.apps.googleusercontent.com
# WebView / full-page OAuth redirect (add "Authorized redirect URI" in the same Web client):
# GOOGLE_CLIENT_SECRET=your-client-secret
FRONTEND_URL=https://dashkan.net
GOOGLE_OAUTH_REDIRECT_URI=https://dashkan.net/api/auth/google/callback
# Local default redirect if unset: http://localhost:${PORT}/api/auth/google/callback
#
# If Apache mod_security shows "Not acceptable" after Gmail: whitelist or tune rules for GET
# /api/auth/google/callback (OAuth sends long `code`/`state` query args). Your host can exclude
# that path from OWASP CRS on ARGS, or proxy OAuth only to the Node process without mod_security.


# Web Push (system notification center)
# Generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=BOE7OAy_eJ119ruvEzL50_grYVKIM71XkR3gO-Sdz-K_sCrzXmRZPy_ZFco0LRnIC-IruBhSccS5i0mzA2dil-8
VAPID_PRIVATE_KEY=7Useh5gVYbqtqJLa4VZSxLD5Cyemhf4scQFQ_7KFvlE

# Firebase Cloud Messaging (Flutter mobile push)
# Option A — path to service account JSON (recommended for local dev):
# FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json
# Option B — inline JSON (single line, for cloud hosts):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option C — individual fields:
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

