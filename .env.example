# Backend environment variables
# Copy to .env and fill in values

# MongoDB connection
MONGO_URI=mongodb://localhost:27017/storeplace

# Server port
PORT=5000

# JWT secret for auth
JWT_SECRET=your-secret-key

# Web Push (system notification center)
# Generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
